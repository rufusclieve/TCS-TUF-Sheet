import java.util.*;

class Main {
    
    public static void getASCI(String str) {
        
        int n = str.length();
        
        for(int i = 0; i < n; i++) {
            
            char ch = str.charAt(i); // A
            
            System.out.println((int)ch);
        }
        
        
    }
    public static void main(String[] args) {
        
        Scanner sc = new Scanner(System.in);
        int testcases = sc.nextInt();
        sc.nextLine();
        
        while(testcases-- > 0) {
            String str = sc.nextLine();
            
            getASCI(str);
        }
        
    
    }
}
